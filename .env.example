# Copy to .env.local for local dev — Vite only exposes vars prefixed VITE_
# to client code. Never commit the real .env.local (already gitignored).
#
# None of these are required to run the app (see scripts/setup-env.js) —
# each integration no-ops gracefully if its var is missing.

# Sentry error monitoring — production only, no-ops if unset.
VITE_SENTRY_DSN=

# PostHog analytics — page views + conversion events, no-ops if unset.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# The real backend (backend/src/server.js). Consumed by src/app/lib/apiClient.js
# — currently only BusinessProjects.jsx uses it; every other page still runs
# on PlatformContext mock state (see TECH_ROADMAP.md's migration plan).
VITE_API_URL=http://localhost:4000
